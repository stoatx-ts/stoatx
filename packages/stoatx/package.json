{
  "name": "stoatx",
  "version": "0.3.0",
  "description": "A high-performance, decorator-based command handler for the Stoat ecosystem.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stoatx-ts/stoatx.git"
  },
  "bugs": {
    "url": "https://github.com/stoatx-ts/stoatx/issues"
  },
  "homepage": "https://github.com/stoatx-ts/stoatx#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts --tsconfig tsconfig.build.json",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "stoat.js": "^7.3.6",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.0"
  }
}
